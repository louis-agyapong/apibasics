{
    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#fad454",
        "activityBar.activeBorder": "#059b78",
        "activityBar.background": "#fad454",
        "activityBar.foreground": "#15202b",
        "activityBar.inactiveForeground": "#15202b99",
        "activityBarBadge.background": "#059b78",
        "activityBarBadge.foreground": "#e7e7e7",
        "statusBar.background": "#f8c723",
        "statusBar.foreground": "#15202b",
        "statusBarItem.hoverBackground": "#e1af07",
        "titleBar.activeBackground": "#f8c723",
        "titleBar.activeForeground": "#15202b",
        "titleBar.inactiveBackground": "#f8c72399",
        "titleBar.inactiveForeground": "#15202b99"
    },
    "peacock.color": "#f8c723",
    "python.linting.flake8Enabled": true,
    "python.linting.enabled": true,
    "python.formatting.provider": "black",
    "python.sortImports.args": [
        "--profile=black",
    ],
    "python.formatting.blackArgs": [
        "--line-length=119"
    ],
    "[python]": {
        "editor.codeActionsOnSave": {
            "source.organizeImports": true
        }
    },
    "python.linting.mypyEnabled": false,
    // Django extension
    "files.associations": {
        "**/*.html": "html",
        "**/templates/**/*.html": "django-html",
        "**/templates/**/*": "django-txt",
        "**/requirements{/**,*}.{txt,in}": "pip-requirements"
    },
    "emmet.includeLanguages": {
        "django-html": "html"
    },
    "python.linting.flake8Args": [
        "--max-line-length=119"
    ],
}